{
  "name": "qfi-a2ui-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite --port 5174\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^22.15.7",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^40.6.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.qfi.a2ui",
    "productName": "QFI AI Advisor"
  }
}
